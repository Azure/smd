        "dov:namespace": "http://opcfoundation.org/UA/SurfaceTechnology/GeneralTypes/",
        "input": {
          "type": "object",
          "dov:typeRef": "org.opcfoundation.UA.InputArguments",
          "required": [ "AliasName", "ReferenceID", "Target" ],
          "properties": {
            "AliasName": {
              "description": "The alias to be assigned to a particular node",
              "type": "string"
            },
            "ReferenceID": {
              "description": "The ID of the reference that should apply to the new alias",
              "type": "string"
            },
            "Target": {
              "description": "The exact node to which the alias should be assigned to",
              "type": "string"
            }
          }
        },
        "output": {
          "type": "object",
          "dov:typeRef": "org.opcfoundation.UA.OutputArguments",
          "required": [ "AliasNode" ],
          "properties": {
            "AliasNode": {
              "description": "The ID of the node that has now been assigned the alias",
              "type": "string"
            }
          }
        },
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/SurfaceTechnology.GeneralTypes/SurfaceTechnology_GeneralTypes_STJobManagementType/action/AddAlias",
            "op": "invokeaction"
          }
        ]
      },
      "RemoveAlias": {
        "dov:namespace": "http://opcfoundation.org/UA/SurfaceTechnology/GeneralTypes/",
        "input": {
          "type": "object",
          "dov:typeRef": "org.opcfoundation.UA.InputArguments",
          "required": [ "AliasName", "ReferenceID" ],
          "properties": {
            "AliasName": {
              "description": "The alias that has to be removed",
              "type": "string"
            },
            "ReferenceID": {
              "description": "The ID of the reference that has to be removed",
              "type": "string"
            }
          }
        },
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/SurfaceTechnology.GeneralTypes/SurfaceTechnology_GeneralTypes_STJobManagementType/action/RemoveAlias",
            "op": "invokeaction"
          }
        ]
      }
    },
