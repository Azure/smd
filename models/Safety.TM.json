      }
    ],
    "@type": "tm:ThingModel",
    "title": "Safety_DataTypes",
    "links": [
    ],
    "schemaDefinitions": {
      "InFlagsType": {
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.Safety.InFlagsType",
        "const": {
          "CommunicationError": 0,
          "OperatorAckRequested": 1,
          "FSV_Activated": 2
        },
        "description": "Byte with Non safety Flags from SafetyConsumer",
        "properties": {
          "CommunicationError": {
            "description": "0: No error,  1: An error was detected in the previous ResponseSPDU.",
            "type": "integer"
          },
          "OperatorAckRequested": {
            "description": "Used to inform the SafetyProvider that operator acknowledgment is requested.",
            "type": "integer"
          },
          "FSV_Activated": {
            "description": "Is used for conformance test of SafetyConsumer.SAPI.FSV_Activated.",
            "type": "integer"
          }
        }
      },
      "NonSafetyDataPlaceholderDataType": {
        "description": "Dummy structure to be used when no non-safety data are used",
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.Safety.NonSafetyDataPlaceholderDataType",
        "required": [ "Dummy" ],
        "properties": {
          "Dummy": {
            "description": "Dummy variable to avoid empty structures",
            "type": "boolean"
          }
        }
      },
      "OutFlagsType": {
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.Safety.OutFlagsType",
        "const": {
          "OperatorAckProvider": 0,
          "ActivateFSV": 1,
          "TestModeActivated": 2
        },
        "description": "Byte with Safety Flags from SafetyProvider",
        "properties": {
          "OperatorAckProvider": {
            "description": "Operator acknowledgment at the provider, hereby forwarded to the SafetyConsumer.",
            "type": "integer"
          },
          "ActivateFSV": {
            "description": "Activation of fail-safe values by the safety application at the SafetyProvider, hereby forwarded to the SafetyConsumer.",
            "type": "integer"
          },
          "TestModeActivated": {
            "description": "Enabling and disabling of test mode in the SafetyProvider, hereby forwarded to the SafetyConsumer.",
            "type": "integer"
          }
        }
      },
      "RequestSPDUDataType": {
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.Safety.RequestSPDUDataType",
        "required": [ "InSafetyConsumerID", "InMonitoringNumber", "InFlags" ],
        "properties": {
          "InSafetyConsumerID": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "InMonitoringNumber": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "InFlags": {
            "title": "InFlagsType",
            "dov:typeRef": "org.opcfoundation.UA.Safety.InFlagsType",
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
          }
        }
      },
      "ResponseSPDUDataType": {
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.Safety.ResponseSPDUDataType",
        "required": [ "OutFlags", "OutSPDU_ID_1", "OutSPDU_ID_2", "OutSPDU_ID_3", "OutSafetyConsumerID", "OutMonitoringNumber", "OutCRC" ],
        "properties": {
          "OutFlags": {
            "title": "OutFlagsType",
            "dov:typeRef": "org.opcfoundation.UA.Safety.OutFlagsType",
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
          },
          "OutSPDU_ID_1": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "OutSPDU_ID_2": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "OutSPDU_ID_3": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "OutSafetyConsumerID": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "OutMonitoringNumber": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "OutCRC": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          }
        }
      }
    },
    "actions": {
    },
    "properties": {
    },
    "events": {
    }
  }
