    "schemaDefinitions": {
      "GlobalLocationDataType": {
        "description": "Represents a global location",
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.GPOS.GlobalLocationDataType",
        "required": [ "Position" ],
        "properties": {
          "Position": {
            "title": "GlobalPositionDataType",
            "description": "Represents a global position",
            "type": "object",
            "dov:typeRef": "org.opcfoundation.UA.GPOS.GlobalPositionDataType",
            "required": [ "Longitude", "Latitude" ],
            "properties": {
              "Longitude": {
                "description": "MUST be interpreted according to the CoordinateReferenceSystem",
