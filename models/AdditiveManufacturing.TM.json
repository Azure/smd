          "MachineHealth": {
            "description": "The sensor is mainly relevant to indicate the current AM machine’s health.",
            "type": "integer"
          },
          "MaintenanceTracking": {
            "description": "The sensor is mainly relevant to track serviceable components.",
            "type": "integer"
