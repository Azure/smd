    "schemaDefinitions": {
      "FeedstockFunction": {
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.AdditiveManufacturing.FeedstockFunction",
        "const": {
          "Undefined": 0,
          "Main": 1,
          "Ancillary": 2,
