        "description": "The LongwallShieldOffsetDataType describes a tuple containing a roof support shield number and its corresponding offset",
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.Mining.General.LongwallShieldOffsetDataType",
        "required": [ "ShieldNumber", "ShieldOffset" ],
        "properties": {
          "ShieldNumber": {
            "description": "The ShieldNumber describes the number of a roof support shield",
            "type": "integer",
            "minimum": 0,
            "maximum": 65535
          },
          "ShieldOffset": {
            "description": "The ShieldOffset describes the offset of a roof support shield",
            "type": "number",
            "minimum": -1.80e+308,
            "maximum": 1.80e+308
          }
        }
      }
