          }
        }
      },
      "RunInfoDataType": {
        "type": "object",
        "dov:typeRef": "org.opcfoundation.UA.AdditiveManufacturing.RunInfoDataType",
        "required": [ "Identifier", "State" ],
        "properties": {
          "CurrentLayer": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          },
          "Identifier": {
            "type": "string"
          },
          "State": {
            "title": "ISA95StateDataType",
            "description": "Defines the information needed to schedule and execute a job.",
            "type": "object",
            "dov:typeRef": "org.opcfoundation.UA.ISA95-JOBCONTROL_V2.ISA95StateDataType",
            "required": [ "BrowsePath", "StateText", "StateNumber" ],
            "properties": {
              "BrowsePath": {
                "title": "RelativePath",
                "description": "The browse path of substates. Shall be null when the top-level state is represented.",
                "type": "object",
                "dov:typeRef": "org.opcfoundation.UA.RelativePath",
                "required": [ "Elements" ],
                "properties": {
                  "Elements": {
                    "type": "array",
                    "items": {
                      "title": "RelativePathElement",
                      "type": "object",
                      "dov:typeRef": "org.opcfoundation.UA.RelativePathElement",
                      "required": [ "ReferenceTypeId", "IsInverse", "IncludeSubtypes", "TargetName" ],
                      "properties": {
                        "ReferenceTypeId": {
                          "type": "string"
                        },
                        "IsInverse": {
                          "type": "boolean"
                        },
                        "IncludeSubtypes": {
                          "type": "boolean"
                        },
                        "TargetName": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "StateText": {
                "description": "The state represented as human readable text. Shall represent the same text as the CurrentState Variable of a StateMachine would.",
                "type": "string"
              },
              "StateNumber": {
                "description": "The state represented as number. Shall represent the same number as the Number subvariable of the CurrentState Variable of a StateMachine would.",
                "type": "integer",
                "minimum": 0,
                "maximum": 4294967295
              }
            }
          },
          "RemainingTime": {
            "type": "string",
            "pattern": "^P(?!$)(?:(?:(?:(?:\\d+Y)|(?:\\d+\\.\\d+Y$))?(?:(?:\\d+M)|(?:\\d+\\.\\d+M$))?)|(?:(?:(?:\\d+W)|(?:\\d+\\.\\d+W$))?))(?:(?:\\d+D)|(?:\\d+\\.\\d+D$))?(?:T(?!$)(?:(?:\\d+H)|(?:\\d+\\.\\d+H$))?(?:(?:\\d+M)|(?:\\d+\\.\\d+M$))?(?:\\d+(?:\\.\\d+)?S)?)?$"
          }
        }
      },
